# SliceMatic — Stage 3 AI layer. Copy to .env and fill in. Never commit .env.

# --- Supabase (orders mirror + AI sessions/messages) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- LLM (OpenRouter, tool-use) ---
OPENROUTER_API_KEY=
PRIMARY_MODEL=google/gemini-2.5-flash
FALLBACK_MODEL_1=anthropic/claude-haiku-4.5
FALLBACK_MODEL_2=openai/gpt-4o-mini

# --- Voice (Deepgram STT + English TTS) ---
DEEPGRAM_API_KEY=

# --- Hindi TTS (Sarvam AI / Bulbul) — optional; English falls back to Deepgram ---
SARVAM_API_KEY=
SARVAM_SPEAKER=anushka
SARVAM_MODEL=bulbul:v2

# --- Auth (user/role management) ---
# JWT signing secret — REQUIRED for any real deploy (dev falls back to a fixed
# insecure default). Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=
# Admin account (seeded, no public signup) — scripts/seed_admin.py or seed_demo_users.py
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=SliceMatic Admin
# Demo accounts, one per role (scripts/seed_demo_users.py; see .env for the
# working set): DEMO_USER_* (customer, phone+PIN), DEMO_STAFF_* (SMEMP001),
# DEMO_KITCHEN_* (SMEMP002), DEMO_DELIVERY_* (SMEMP003)

# --- Observability (Langfuse free tier) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Optional: enables a clickable Langfuse session link on escalations
LANGFUSE_PROJECT_ID=
