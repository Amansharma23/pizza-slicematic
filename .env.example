# SliceMatic — Stage 3 AI layer. Copy to .env and fill in. Never commit .env.

# --- Supabase (orders mirror + AI sessions/messages) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- LLM (OpenRouter, tool-use) ---
OPENROUTER_API_KEY=
PRIMARY_MODEL=google/gemini-2.5-flash
FALLBACK_MODEL_1=anthropic/claude-haiku-4.5
FALLBACK_MODEL_2=openai/gpt-4o-mini

# --- Voice (Deepgram STT + TTS) ---
DEEPGRAM_API_KEY=

# --- Observability (Langfuse free tier) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Optional: enables a clickable Langfuse session link on escalations
LANGFUSE_PROJECT_ID=
