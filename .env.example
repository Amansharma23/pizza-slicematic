# SliceMatic - Stage 3 local/deploy env. Copy to .env and fill in.
# Never commit .env.

# --- Database provider ---
# Local Stage 0:
DATABASE_PROVIDER=postgres
DATABASE_URL=postgresql://slicematic_user:slicematic_local@localhost:5432/slicematic_local

# Future/deploy Supabase path:
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- AI providers ---
# Admin AI features should use this provider selection once implemented.
AI_PROVIDER=mock
ADMIN_AI_PROVIDER=mock
ADMIN_AI_MODEL=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
PRIMARY_MODEL=google/gemini-2.5-flash
FALLBACK_MODEL_1=anthropic/claude-haiku-4.5
FALLBACK_MODEL_2=openai/gpt-4o-mini
GUARDRAIL_MODEL=openai/gpt-4o-mini

# --- Voice (Deepgram STT + English TTS) ---
DEEPGRAM_API_KEY=

# --- Hindi TTS (Sarvam AI / Bulbul) — optional; English falls back to Deepgram ---
SARVAM_API_KEY=
SARVAM_SPEAKER=anushka
SARVAM_MODEL=bulbul:v2
# Realtime voice call (ai/sarvam_stream.py, WS /voice/call) — bulbul:v3 for
# native Hinglish. v3 has its own speaker roster; v2 speakers (e.g. "abhilash")
# are invalid on v3, which is why this is separate from SARVAM_SPEAKER above.
SARVAM_V3_SPEAKER=priya

# --- Auth (user/role management) ---
# JWT signing secret — REQUIRED for any real deploy (dev falls back to a fixed
# insecure default). Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_JWT_SECRET=
# Admin account (seeded, no public signup) — scripts/seed_admin.py or seed_demo_users.py
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=SliceMatic Admin
# Demo accounts, one per role (scripts/seed_demo_users.py; see .env for the
# working set): DEMO_USER_* (customer, phone+PIN), DEMO_STAFF_* (SMEMP001),
# DEMO_KITCHEN_* (SMEMP002), DEMO_DELIVERY_* (SMEMP003)

# --- Observability (Langfuse free tier) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PROJECT_ID=

# --- Notifications (mock locally until provider is chosen) ---
WHATSAPP_PROVIDER=mock
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
EMAIL_PROVIDER=mock
EMAIL_API_KEY=
EMAIL_FROM=

# --- Local app config ---
AI_CORS_ORIGINS=http://localhost:3000
MENU_DIR=menu_data
DATABASE_DIR=database

# --- Local admin dev auth ---
ADMIN_DEV_EMAIL=admin@slicematic.local
ADMIN_DEV_TOKEN=replace-with-local-dev-token

# --- Local staff dev auth ---
STAFF_DEV_EMAIL=kitchen@slicematic.local
STAFF_DEV_TOKEN=replace-with-local-staff-token
