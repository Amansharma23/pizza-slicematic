{
  "info": {
    "name": "SliceMatic AI API",
    "description": "REST + conversational endpoints for the SliceMatic ordering system (ai/main.py). Set {{base_url}} (default http://localhost:7860). See docs/API.md.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:7860" },
    { "key": "session_id", "value": "demo-session-1" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{base_url}}/health" }
    },
    {
      "name": "Core REST (/api)",
      "item": [
        {
          "name": "Get menu",
          "request": { "method": "GET", "url": "{{base_url}}/api/menu" }
        },
        {
          "name": "Validate customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/validate/customer",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Aman Sharma\",\n  \"phone\": \"9811122233\"\n}" }
          }
        },
        {
          "name": "Summary (itemised bill)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/summary",
            "body": { "mode": "raw", "raw": "{\n  \"base_id\": \"B1\",\n  \"pizza_id\": \"P1\",\n  \"topping_id\": \"T1\",\n  \"quantity\": 5\n}" }
          }
        },
        {
          "name": "Place order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/order",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Aman Sharma\",\n  \"phone\": \"9811122233\",\n  \"base_id\": \"B1\",\n  \"pizza_id\": \"P1\",\n  \"topping_id\": \"T1\",\n  \"quantity\": 2,\n  \"payment_mode\": \"UPI\"\n}" }
          }
        },
        {
          "name": "Get config (discount rate)",
          "request": { "method": "GET", "url": "{{base_url}}/api/config" }
        },
        {
          "name": "Set config (discount rate)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/config",
            "body": { "mode": "raw", "raw": "{\n  \"discount_rate\": 0.10\n}" }
          }
        },
        {
          "name": "Analytics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/analytics?filter_type=All Time",
              "host": ["{{base_url}}"],
              "path": ["api", "analytics"],
              "query": [{ "key": "filter_type", "value": "All Time" }]
            }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Chat turn",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/chat",
            "body": { "mode": "raw", "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"message\": \"I'd like 2 thin crust margherita pizzas with black olives. Name Aman Sharma, phone 9811122233, paying UPI.\"\n}" }
          }
        },
        {
          "name": "Chat confirm",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/chat",
            "body": { "mode": "raw", "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"message\": \"Yes, confirm and place it.\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Voice",
      "item": [
        {
          "name": "Transcribe (STT)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/voice/transcribe",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "session_id", "value": "{{session_id}}", "type": "text" },
                { "key": "audio", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Respond (agent)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/voice/respond",
            "body": { "mode": "raw", "raw": "{\n  \"session_id\": \"{{session_id}}\",\n  \"transcript\": \"I want two margherita pizzas\"\n}" }
          }
        },
        {
          "name": "Synthesize (TTS)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/voice/synthesize",
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Your order is confirmed!\",\n  \"language\": \"en\"\n}" },
            "description": "Returns audio/mpeg bytes."
          }
        }
      ]
    }
  ]
}
